# Variables d'environnement Nexperio
# ───────────────────────────────────────────────────────
# Copier ce fichier en `.env.local` (jamais committé) pour le dev local,
# et reproduire les mêmes clés dans Vercel → Settings → Environment Variables.

# ─── Supabase (lecture publique : blog) ─────────────────
# Le préfixe NEXT_PUBLIC_ rend la clé accessible côté client.
# La publishable key est faite pour ça : aucun risque à l'exposer.
NEXT_PUBLIC_SUPABASE_URL=https://qarqnjzixkkunhdzgule.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_3xuBGegF0JxWO8tnrQoXkA_tSgoh1TO

# ─── Supabase (écriture côté serveur uniquement) ────────
# À récupérer dans Supabase → Settings → API → "service_role" key.
# NE JAMAIS préfixer NEXT_PUBLIC_ et NE JAMAIS commiter.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Resend (envoi d'email) ─────────────────────────────
# À récupérer dans Resend → API Keys.
RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── Calendly ───────────────────────────────────────────
# URL publique vers le créneau de consultation.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/nexperio-france/l-ordonnance-express-du-docteur-digital
